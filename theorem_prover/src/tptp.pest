WHITESPACE = _{ " " | "\t" | NEWLINE | COMMENT }
NEWLINE = _{ "\r\n" | "\n" | "\r" }
COMMENT = _{ "%" ~ (!NEWLINE ~ ANY)* }

file = {SOI ~ annotated_formula* ~ EOI}
annotated_formula = { "fof" ~ "(" ~ name ~ "," ~ role ~ "," ~ formula ~ ")" ~ "." }

name = @{ (ASCII_ALPHANUMERIC | "_")+ }
role = @{ (ASCII_ALPHANUMERIC | "_")+ }

formula = { atom }
atom = @{ (ASCII_ALPHANUMERIC | "_")+ }


